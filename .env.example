# ─── Required ──────────────────────────────────────────────
# Database (docker compose up -d starts Postgres automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# LLM — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Optional ──────────────────────────────────────────────
# Sandbox computer — sign up at https://app.daytona.io
# Leave blank to disable computer tools (chat + memory still work)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# OpenAI (for Codex features, optional)
OPENAI_API_KEY=

# TTS (optional)
CARTESIA_API_KEY=

# Auth
BETTER_AUTH_SECRET=dev-secret-change-in-prod
BETTER_AUTH_URL=http://localhost:3000
