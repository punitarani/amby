# Database (docker compose up -d starts Postgres automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Auth — BetterAuth
BETTER_AUTH_SECRET=dev-secret-change-in-prod
BETTER_AUTH_URL=http://localhost:3000

# LLM, STT, TTS
OPENROUTER_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

# Daytona Sandbox — sign up at https://app.daytona.io
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Computer / Sandbox
ENABLE_CUA=true

# Telegram bot — get a token from @BotFather
TELEGRAM_BOT_TOKEN=
# Secret to verify webhook requests come from Telegram (set via setup-webhook script)
TELEGRAM_WEBHOOK_SECRET=

# PostHog analytics
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ngrok for local development
NGROK_DOMAIN=
