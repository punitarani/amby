# Doppler is the primary secret manager for this project.
# Run `doppler setup` to configure, then use `bun run dev` (scripts auto-wrap with `doppler run`).
# For Wrangler local dev, run `bun run dev:vars` to generate apps/api/.dev.vars from Doppler.
#
# This .env file is a fallback for contributors without Doppler access.
# Copy to .env and fill in values manually.

NODE_ENV=development

# API URL — base URL of the deployed API
API_URL=

# Web app URL — canonical website/domain
APP_URL=

# Database (docker compose up -d starts Postgres automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Auth — BetterAuth
BETTER_AUTH_SECRET=dev-secret-change-in-prod
BETTER_AUTH_URL=http://localhost:3001

# Cloudflare API for Workers, Browser Rendering, and AI Gateway
# Create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_GATEWAY_ID=
CLOUDFLARE_AI_GATEWAY_BASE_URL=
CLOUDFLARE_AI_GATEWAY_AUTH_TOKEN=

# LLM, STT, TTS
OPENROUTER_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

# Daytona Sandbox — sign up at https://app.daytona.io
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Computer / Sandbox
ENABLE_CUA=true

# Telegram bot — get a token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=my_amby_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=my_amby_bot
# Secret to verify webhook requests come from Telegram (set via setup-webhook script)
TELEGRAM_WEBHOOK_SECRET=
ATTACHMENTS_SIGNING_SECRET=dev-attachments-secret
TELEGRAM_LOGIN_WIDGET_ENABLED=true
TELEGRAM_MINI_APP_ENABLED=false
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REQUEST_PHONE=false
TELEGRAM_OIDC_REQUEST_BOT_ACCESS=false
TELEGRAM_MAX_AUTH_AGE_SECONDS=86400

# Composio connectors
COMPOSIO_API_KEY=
COMPOSIO_WEBHOOK_SECRET=
COMPOSIO_AUTH_CONFIG_GMAIL=
COMPOSIO_AUTH_CONFIG_GOOGLECALENDAR=
COMPOSIO_AUTH_CONFIG_NOTION=
COMPOSIO_AUTH_CONFIG_SLACK=
COMPOSIO_AUTH_CONFIG_GOOGLEDRIVE=

# Braintrust — agent observability & tracing
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_ID=

# Sentry — error tracking
SENTRY_DSN=

# ngrok for local development
NGROK_DOMAIN=
