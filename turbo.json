{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"lint": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"passThroughEnv": ["DATABASE_URL"]
		},
		"db:push": {
			"cache": false
		}
	}
}
