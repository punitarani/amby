{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"test": {},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"format": {},
		"format:check": {},
		"lint": {},
		"lint:fix": {},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"cache": false,
			"passThroughEnv": ["DATABASE_URL"]
		},
		"db:migrate": {
			"cache": false,
			"passThroughEnv": ["DATABASE_URL"]
		},
		"db:push": {
			"cache": false,
			"passThroughEnv": ["DATABASE_URL"]
		},
		"db:studio": {
			"cache": false,
			"passThroughEnv": ["DATABASE_URL"]
		}
	}
}
