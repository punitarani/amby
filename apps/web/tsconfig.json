{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "es2022"],
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "@effect/language-service",
				"ignoreEffectWarningsInTscExitCode": true
			},
			{ "name": "next" }
		],
		"types": ["node"],
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
