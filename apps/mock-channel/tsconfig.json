{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"noEmit": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./app/*", "./components/*", "./lib/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules"]
}
