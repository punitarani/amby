{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "es2022"],
		"jsx": "preserve",
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"types": ["node", "bun-types"],
		"paths": {
			"@/*": ["./*"],
			"@amby/auth": ["../../packages/auth/src/index.ts"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
