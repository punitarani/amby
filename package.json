{
	"name": "amby",
	"version": "0.1.0",
	"private": true,
	"description": "Amby - your personal ambient assistant",
	"scripts": {
		"prepare": "if [ \"${CI:-}\" = \"1\" ] || [ \"${CI:-}\" = \"true\" ]; then exit 0; else effect-language-service patch; fi",
		"format": "bunx @biomejs/biome format --write .",
		"format:check": "bunx @biomejs/biome format .",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --fix .",
		"devtools:check": "effect-language-service check",
		"test": "turbo test",
		"test:coverage": "bun test --coverage",
		"test:coverage:lcov": "bun test --coverage --coverage-reporter=lcov",
		"typecheck": "(effect-language-service check >/dev/null 2>&1 || effect-language-service patch) && turbo typecheck",
		"build": "turbo build",
		"dev": "doppler run -- turbo dev",
		"web": "bun run --filter @amby/web start",
		"web:dev": "bun run --filter @amby/web dev",
		"db:generate": "turbo db:generate --filter=@amby/db",
		"db:migrate": "doppler run -- turbo db:migrate --filter=@amby/db",
		"db:push": "doppler run -- turbo db:push --filter=@amby/db",
		"db:studio": "doppler run -- turbo db:studio --filter=@amby/db",
		"seed": "doppler run -- bun run scripts/seed.ts",
		"test:telegram": "doppler run -- bash -c 'cd apps/api && bun run src/scripts/test-telegram-flow.ts'",
		"setup": "docker compose up -d && bun install && bun run db:push && bun run seed",
		"api": "doppler run -- bun run apps/api/src/index.ts",
		"api:dev": "doppler run -- bun run --hot apps/api/src/index.ts",
		"dev:vars": "doppler run -- ./scripts/generate-dev-vars.sh",
		"api:dev:worker": "bun run dev:vars && cd apps/api && wrangler dev",
		"computer:docker:build": "./docker/computer/build.sh",
		"computer:docker:push": "./docker/computer/push.sh",
		"computer:snapshot:create": "bun run --cwd packages/computer create-snapshot",
		"tunnel": "doppler run -- ./scripts/tunnel.sh",
		"docs:notion:pull": "cd docs && doppler run -- notionfs pull",
		"docs:notion:push": "cd docs && doppler run -- notionfs push",
		"docs:notion:sync": "cd docs && doppler run -- notionfs sync"
	},
	"packageManager": "bun@1.3.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"dependencies": {
		"ai": "^6.0.116",
		"effect": "^3.21.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@effect/language-service": "^0.83.1",
		"@biomejs/biome": "^2.4.7",
		"bun-types": "^1.3.10",
		"turbo": "^2.8.19",
		"typescript": "^5.8.0",
		"wrangler": "^4.73.0"
	}
}
