{
	"name": "@amby/attachments",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./local": "./src/local.ts",
		"./workers": "./src/workers.ts"
	},
	"scripts": {
		"test": "bun test",
