{
	"name": "@amby/db",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "bun build ./src/index.ts --outdir dist --target bun",
		"db:generate": "drizzle-kit generate",
		"db:generate:check": "bun run ./scripts/check-generated-migrations.ts",
		"db:check": "drizzle-kit check",
		"db:migrate": "drizzle-kit migrate",
		"db:validate": "bun run db:generate:check && bun run db:migrate && bun run db:check",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@amby/core": "workspace:*",
		"@amby/env": "workspace:*",
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.7"
	},
	"peerDependencies": {
		"effect": "^3.21.0"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.0"
	}
}
